@model List<SinfraRMM.Web.Dtos.AuditLogDto>
@{
    ViewData["Title"] = "Audit Log";
    var servers  = ViewBag.Servers as List<SinfraRMM.Web.Dtos.ServerDto> ?? new();
    var total    = (int)ViewBag.Total;
    var page     = (int)ViewBag.Page;
    var pageSize = (int)ViewBag.PageSize;
    var pages    = (int)Math.Ceiling((double)total / pageSize);
}

<div class="container-fluid px-4 py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0">📋 Audit Log</h5>
            <small class="text-muted">@total registro(s) en total</small>
        </div>
    </div>

    <!-- Filtros -->
    <form method="get" class="d-flex gap-2 mb-3">
        <!-- Filtro servidores -->
<select name="serverId" class="form-select form-select-sm"
        style="width:200px; background:#1a1d27; color:#e0e0e0; border-color:#2a2d3a">
    <option value="">Todos los servidores</option>
    @foreach (var s in servers)
    {
        @if (ViewBag.ServerId?.ToString() == s.Id.ToString())
        {
            <option value="@s.Id" selected>@s.AssetCode — @s.Name</option>
        }
        else
        {
            <option value="@s.Id">@s.AssetCode — @s.Name</option>
        }
    }
</select>

<!-- Filtro status -->
<select name="status" class="form-select form-select-sm"
        style="width:150px; background:#1a1d27; color:#e0e0e0; border-color:#2a2d3a">
    <option value="">Todos los estados</option>
    @if (ViewBag.Status == "Done")
    {
        <option value="Done" selected>Done</option>
        <option value="Error">Error</option>
    }
    else if (ViewBag.Status == "Error")
    {
        <option value="Done">Done</option>
        <option value="Error" selected>Error</option>
    }
    else
    {
        <option value="Done">Done</option>
        <option value="Error">Error</option>
    }
</select>
        <button type="submit" class="btn btn-sm btn-outline-primary">Filtrar</button>
        <a href="/AuditLogs" class="btn btn-sm btn-outline-secondary">Limpiar</a>
    </form>

    <!-- Tabla -->
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr style="border-color:#2a2d3a">
                        <th class="px-3 py-3 text-muted small">#</th>
                        <th class="py-3 text-muted small">SERVIDOR</th>
                        <th class="py-3 text-muted small">COMANDO</th>
                        <th class="py-3 text-muted small">OUTPUT</th>
                        <th class="py-3 text-muted small">ESTADO</th>
                        <th class="py-3 text-muted small">USUARIO</th>
                        <th class="py-3 text-muted small">FECHA</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                Sin registros.
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        <tr style="border-color:#2a2d3a">
                            <td class="px-3 py-3 text-muted">@log.Id</td>
                            <td class="py-3">
                                <span class="badge bg-secondary me-1">@log.AssetCode</span>
                                @log.Server
                            </td>
                            <td class="py-3">
                                <small class="font-monospace text-info">@log.Command</small>
                            </td>
                            <td class="py-3" style="max-width:300px">
                                <pre class="mb-0 text-muted" style="font-size:0.7rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:300px">@log.ActionOutput</pre>
                            </td>
                            <td class="py-3">
                                <span class="badge @(log.Status == "Done" ? "bg-success" : "bg-danger")">
                                    @log.Status
                                </span>
                            </td>
                            <td class="py-3">
                                <small class="text-muted">@log.User</small>
                            </td>
                            <td class="py-3">
                                <small class="text-muted">@log.CreatedAt.ToString("dd/MM HH:mm:ss")</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (pages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-end">
                @for (int i = 1; i <= pages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link"
                           href="/AuditLogs?page=@i@(ViewBag.ServerId != null ? $"&serverId={ViewBag.ServerId}" : "")@(ViewBag.Status != null ? $"&status={ViewBag.Status}" : "")">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>