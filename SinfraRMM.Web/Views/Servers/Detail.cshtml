@model SinfraRMM.Web.Models.ServerDetailViewModel
@{
    ViewData["Title"] = Model.Server.Name;
}

<div class="container-fluid px-4 py-3">

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
        <div>
            <h5 class="mb-0">@Model.Server.Name</h5>
            <small class="text-muted">@Model.Server.AssetCode · @Model.Server.IpAddress</small>
        </div>
        <span class="badge @(Model.Server.Status == "Online" ? "bg-success" : "bg-danger") ms-auto">
            @Model.Server.Status
        </span>
    </div>

    <div class="row g-3">

        <!-- Info del servidor -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted small text-uppercase mb-3">Información</h6>
                    <table class="table table-sm table-dark table-borderless mb-0">
                        <tr>
                            <td class="text-muted">OS</td>
                            <td>@(Model.Server.OsInfo ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">IP</td>
                            <td>@Model.Server.IpAddress</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Categoría</td>
                            <td>@Model.Server.Category</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Último contacto</td>
                            <td>@(Model.Server.LastHeartbeat?.ToString("dd/MM HH:mm:ss") ?? "Nunca")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Registrado</td>
                            <td>@Model.Server.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    </table>

                    <div class="mt-3">
                        <a asp-action="Console" asp-route-id="@Model.Server.Id"
                           class="btn btn-primary btn-sm w-100">
                            🖥️ Abrir Consola
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Historial de comandos -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title text-muted small text-uppercase mb-3">
                        Historial de Comandos
                    </h6>

                    @if (!Model.History.Any())
                    {
                        <p class="text-muted small">Sin comandos ejecutados aún.</p>
                    }
                    else
                    {
                        @foreach (var log in Model.History)
                        {
                            <div class="mb-3 border-start border-2 @(log.Status == "Done" ? "border-success" : "border-danger") ps-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-bold">@log.Command</span>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="badge @(log.Status == "Done" ? "bg-success" : "bg-danger") small">
                                            @log.Status
                                        </span>
                                        <span class="text-muted" style="font-size:0.75rem">
                                            @log.CreatedAt.ToString("HH:mm:ss")
                                        </span>
                                    </div>
                                </div>
                                <pre class="mb-0 p-2 rounded small"
                                     style="background:#0f1117; color:#a0aec0; max-height:120px; overflow-y:auto; font-size:0.75rem;">@log.ActionOutput</pre>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</div>