<!-- Views/Users/Index.cshtml -->
@model List<SinfraRMM.Web.Dtos.UserDto>
@{
    ViewData["Title"] = "Usuarios";
    var pending = Model.Where(u => u.Status == "Pending").ToList();
    var active  = Model.Where(u => u.Status != "Pending").ToList();
}

<div class="container-fluid px-4 py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0"> Usuarios</h5>
            <small class="text-muted">@Model.Count usuario(s) registrado(s)</small>
        </div>
        @if (pending.Any())
        {
            <span class="badge bg-warning text-dark">
                 @pending.Count pendiente(s) de aprobación
            </span>
        }
    </div>

    <!-- Pendientes de aprobación -->
    @if (pending.Any())
    {
        <div class="alert alert-warning mb-4">
            <h6 class="mb-3"> Usuarios pendientes de aprobación</h6>
            @foreach (var user in pending)
            {
                <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-warning">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center"
                             style="width:32px;height:32px;font-size:0.8rem;color:#000">
                            @user.Email[0].ToString().ToUpper()
                        </div>
                        <div>
                            <div class="fw-bold">@user.Email</div>
                            <small class="text-muted">
                                @(user.Provider == "Google" ? " Google" : " Microsoft") · 
                                Registrado @user.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-success btn-approve"
                                data-user-id="@user.Id">
                             Aprobar
                        </button>
                        <button class="btn btn-sm btn-danger btn-disable"
                                data-user-id="@user.Id">
                             Rechazar
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Tabla usuarios activos/deshabilitados -->
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr style="border-color:#2a2d3a">
                        <th class="px-3 py-3 text-muted small">EMAIL</th>
                        <th class="py-3 text-muted small">ROL</th>
                        <th class="py-3 text-muted small">PROVIDER</th>
                        <th class="py-3 text-muted small">STATUS</th>
                        <th class="py-3 text-muted small">REGISTRADO</th>
                        <th class="py-3 text-muted small">CAMBIAR ROL</th>
                        <th class="py-3 text-muted small">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in active)
                    {
                        <tr style="border-color:#2a2d3a" id="user-row-@user.Id">
                            <td class="px-3 py-3">
                                <div class="d-flex align-items-center gap-2">
                                    @if (user.AvatarUrl is not null)
                                    {
                                        <img src="@user.AvatarUrl" width="28" height="28"
                                             class="rounded-circle"/>
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                                             style="width:28px;height:28px;font-size:0.7rem">
                                            @user.Email[0].ToString().ToUpper()
                                        </div>
                                    }
                                    <span>@user.Email</span>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Auditor" ? "bg-info" : "bg-secondary")">
                                    @user.Role
                                </span>
                            </td>
                            <td class="py-3">
                                <small class="text-muted">
                                    @(user.Provider == "Local" ? " Local" : user.Provider == "Google" ? "🔵 Google" : "🟦 Microsoft")
                                </small>
                            </td>
                            <td class="py-3">
                                <span class="badge @(user.Status == "Active" ? "bg-success" : "bg-danger")">
                                    @user.Status
                                </span>
                            </td>
                            <td class="py-3">
                                <small class="text-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td class="py-3">
                                <select class="form-select form-select-sm role-select"
                                        style="width:140px; background:#0f1117; color:#e0e0e0; border-color:#2a2d3a"
                                        data-user-id="@user.Id">
                                    @if (user.Role == "Admin")
                                    {
                                        <option value="1" selected>Admin</option>
                                        <option value="2">Tecnico</option>
                                        <option value="3">Auditor</option>
                                    }
                                    else if (user.Role == "Tecnico")
                                    {
                                        <option value="1">Admin</option>
                                        <option value="2" selected>Tecnico</option>
                                        <option value="3">Auditor</option>
                                    }
                                    else
                                    {
                                        <option value="1">Admin</option>
                                        <option value="2">Tecnico</option>
                                        <option value="3" selected>Auditor</option>
                                    }
                                </select>
                            </td>
                            <td class="py-3">
                                @if (user.Status == "Active")
                                {
                                    <button class="btn btn-sm btn-outline-danger btn-disable"
                                            data-user-id="@user.Id">
                                        Deshabilitar
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success btn-approve"
                                            data-user-id="@user.Id">
                                        Habilitar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div id="user-toast" class="toast align-items-center text-white border-0">
            <div class="d-flex">
                <div class="toast-body" id="user-toast-body"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const apiUrl = "@DotNetEnv.Env.GetString("API_URL")";

    // SignalR — cuando llega un nuevo usuario pendiente
    const connection = new signalR.HubConnectionBuilder()
        .withUrl(`${apiUrl}/hubs/monitor`)
        .withAutomaticReconnect()
        .build();

    connection.on("NewUserPending", data => {
        showToast(` Nuevo usuario pendiente: ${data.email}`, "warning");
        setTimeout(() => location.reload(), 2000);
    });

    connection.start().catch(console.error);

    // Aprobar
    document.querySelectorAll(".btn-approve").forEach(btn => {
        btn.addEventListener("click", async () => {
            const userId = btn.dataset.userId;
            const res = await fetch("/Users/Approve", {
                method:  "POST",
                headers: { "Content-Type": "application/json" },
                body:    JSON.stringify({ userId })
            });
            if (res.ok) {
                showToast(" Usuario aprobado.", "success");
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast("Error al aprobar.", "danger");
            }
        });
    });

    // Deshabilitar
    document.querySelectorAll(".btn-disable").forEach(btn => {
        btn.addEventListener("click", async () => {
            const userId = btn.dataset.userId;
            const res = await fetch("/Users/Disable", {
                method:  "POST",
                headers: { "Content-Type": "application/json" },
                body:    JSON.stringify({ userId })
            });
            if (res.ok) {
                showToast("Usuario deshabilitado.", "success");
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast("Error al deshabilitar.", "danger");
            }
        });
    });

    // Cambio de rol
    document.querySelectorAll(".role-select").forEach(select => {
        select.addEventListener("change", async () => {
            const userId = select.dataset.userId;
            const roleId = parseInt(select.value);
            const res = await fetch("/Users/ChangeRole", {
                method:  "POST",
                headers: { "Content-Type": "application/json" },
                body:    JSON.stringify({ userId, roleId })
            });
            const toast = document.getElementById("user-toast");
            if (res.ok) {
                showToast(" Rol actualizado.", "success");
            } else {
                showToast(" Error al actualizar rol.", "danger");
            }
        });
    });

    function showToast(message, type = "success") {
        const toast = document.getElementById("user-toast");
        const body  = document.getElementById("user-toast-body");
        body.textContent = message;
        toast.className  = `toast align-items-center text-white bg-${type} border-0`;
        new bootstrap.Toast(toast, { delay: 3000 }).show();
    }
</script>
}