@model SinfraRMM.Web.Models.Auth.LoginViewModel
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>SinfraRMM — Acceso</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            height: 100vh;
            display: flex;
            font-family: 'Segoe UI', sans-serif;
            background: #0f1117;
        }

        /* Panel izquierdo */
        .left-panel {
            width: 45%;
            background: linear-gradient(145deg, #0f1117 0%, #1a1d27 50%, #0f1117 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            border-right: 1px solid #2a2d3a;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(77,159,255,0.08) 0%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #4d9fff, #0066cc);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .brand-name {
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .brand-name span { color: #4d9fff; }

        .left-content {
            position: relative;
            z-index: 1;
        }

        .left-content h2 {
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .left-content p {
            color: #6b7280;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .stats {
            display: flex;
            gap: 2rem;
            margin-top: 2rem;
        }

        .stat {
            text-align: center;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #4d9fff;
        }

        .stat-label {
            font-size: 0.75rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .left-footer {
            color: #4b5563;
            font-size: 0.75rem;
        }

        /* Panel derecho */
        .right-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            background: #0f1117;
        }

        .login-box {
            width: 100%;
            max-width: 400px;
        }

        .login-box h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.4rem;
        }

        .login-box .subtitle {
            color: #6b7280;
            font-size: 0.875rem;
            margin-bottom: 2rem;
        }

        .form-label {
            color: #9ca3af;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
        }

        .form-control {
            background: #1a1d27;
            border: 1px solid #2a2d3a;
            color: #fff;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .form-control:focus {
            background: #1a1d27;
            border-color: #4d9fff;
            color: #fff;
            box-shadow: 0 0 0 3px rgba(77,159,255,0.1);
        }

        .form-control::placeholder { color: #4b5563; }

        .btn-login {
            background: linear-gradient(135deg, #4d9fff, #0066cc);
            border: none;
            color: #fff;
            padding: 0.75rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            width: 100%;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-login:hover { opacity: 0.9; }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: #4b5563;
            font-size: 0.8rem;
            margin: 1.5rem 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #2a2d3a;
        }

        .btn-oauth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.7rem;
            border-radius: 8px;
            border: 1px solid #2a2d3a;
            background: #1a1d27;
            color: #e0e0e0;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none;
            transition: border-color 0.2s, background 0.2s;
            margin-bottom: 0.75rem;
        }

        .btn-oauth:hover {
            border-color: #4d9fff;
            background: #1e2233;
            color: #fff;
        }

        .alert-custom {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid rgba(220, 53, 69, 0.3);
            color: #f87171;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1.25rem;
        }

        .alert-pending {
            background: rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(251, 191, 36, 0.3);
            color: #fbbf24;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1.25rem;
        }
    </style>
</head>
<body>

<!-- Panel izquierdo -->
<div class="left-panel">
    <div class="brand">
        <div class="brand-icon">⚙️</div>
        <div class="brand-name">Sinfra<span>RMM</span></div>
    </div>

    <div class="left-content">
        <h2>Gestión de<br/>infraestructura<br/>en tiempo real</h2>
        <p>Monitoreo, ejecución de comandos y auditoría centralizada para tus servidores Linux.</p>
        <div class="stats">
            <div class="stat">
                <div class="stat-value">24/7</div>
                <div class="stat-label">Monitoreo</div>
            </div>
            <div class="stat">
                <div class="stat-value">&lt;5s</div>
                <div class="stat-label">Latencia</div>
            </div>
            <div class="stat">
                <div class="stat-value">100%</div>
                <div class="stat-label">Trazabilidad</div>
            </div>
        </div>
    </div>

    <div class="left-footer">
        © 2026 SinfraRMM · Infraestructura segura
    </div>
</div>

<!-- Panel derecho -->
<div class="right-panel">
    <div class="login-box">

        <h3>Bienvenido</h3>
        <p class="subtitle">Ingresa tus credenciales para continuar</p>

        @if (TempData["Pending"] is string pendingMsg)
        {
            <div class="alert-pending">⏳ @pendingMsg</div>
        }

        @if (Model.error is not null)
        {
            <div class="alert-custom">⚠️ @Model.error</div>
        }

        <form asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="returnUrl"/>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control"
                       placeholder="admin@empresa.com"
                       autocomplete="email"/>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password" type="password"
                       class="form-control"
                       placeholder="••••••••"
                       autocomplete="current-password"/>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-login">Iniciar sesión</button>
        </form>

        <div class="divider">o continúa con</div>

        <a href="/Auth/ExternalLogin?provider=Google" class="btn-oauth">
            <svg width="18" height="18" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continuar con Google
        </a>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>